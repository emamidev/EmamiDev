<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:html="http://www.w3.org/1999/xhtml"
	controllerName="com.arteriatech.ss.soinvcreate.cp.controller.SOList" displayBlock="true" id="ListScreen">
	<App id="ListApp">
		<pages>
			<Page title="{i18n>SOList.Page.title}" id="ListPage">
				<content>
					<mvc:XMLView id="ListView" viewName="com.arteriatech.ss.soinvcreate.cp.view.List"/>
				</content>
				<footer>
					<Toolbar>
						<Button id="oMessagePopoverButton" text="{= ${LocalViewSetting>/messageLength} === 0 ? '' : ${LocalViewSetting>/messageLength} }"
							icon="{= ${LocalViewSetting>/messageLength} === 0 ? '' : 'sap-icon://alert' }" press="showPopUp"
							type="{= ${LocalViewSetting>/messageLength} === 0 ? 'Default' : 'Emphasized' }"
							enabled="{= ${LocalViewSetting>/messageLength} === 0 ? false : true }"/>
						<ToolbarSpacer/>
						<!-- <Button text="Simulation" type="Emphasized" press="onPressSimulation" /> -->
						<Button text="Bulk Invoice" type="Emphasized" press="onPressBulkBilling" />
						<Button text="{i18n>List.Footer.StockCheck}" type="Accept" icon="sap-icon://check-availability" press="onStockCheck"
							visible="{LocalViewSetting>/footerBtnVisible}"/>
						<!--<Button text="{i18n>List.Footer.CreateInvoice}" id="bulkInvoice" type="Accept" icon="sap-icon://activities" press="onCreateInvoice"-->
						<!--visible="{LocalViewSetting>/footerBtnVisible}"/>-->
						<!--<Button text="{i18n>List.Footer.CreateInvoice}" id="bulkInvoice" type="Accept" icon="sap-icon://activities" press="onCreateInvoice"-->
						<!--	visible="true"/>-->
					</Toolbar>
				</footer>
			</Page>
		</pages>
	</App>
</mvc:View>