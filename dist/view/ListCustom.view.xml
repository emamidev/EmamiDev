					<table:Column sortProperty="FirstName" filterProperty="FirstName" tooltip="{SSGW_SLS>/#SSSO/SPNo/@sap:label}">
						<Text text="{SSGW_SLS>/#SSSO/SPNo/@sap:label}"/>
						<table:template>
							<Text text="{= ${SOItems>SPNo} !== '' ? ${SOItems>FirstName} +' ('+ ${SOItems>SPNo}+')' : ${SOItems>FirstName} }"
								tooltip="{SSGW_SLS>/#SSSO/SPNo/@sap:label}"/>
						</table:template>
					</table:Column>
					<table:Column sortProperty="SoldToDesc" filterProperty="SoldToDesc" tooltip="{SSGW_SLS>/#SSSO/SoldToId/@sap:label}">
						<Text text="{SSGW_SLS>/#SSSO/SoldToId/@sap:label}"/>
						<table:template>
							<Text text="{= ${SOItems>SoldToId} !== '' ? ${SOItems>SoldToDesc} +' ('+ ${SOItems>SoldToId}+')' : ${SOItems>SoldToDesc} }"
								tooltip="{SSGW_SLS>/#SSSO/SoldToId/@sap:label}"/>
