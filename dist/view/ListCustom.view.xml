						tooltip="{SSGW_SLS>/#SSSO/OrderDate/@sap:label}">
						<Text text="{SSGW_SLS>/#SSSO/OrderDate/@sap:label}" hAlign="Right"/>
						<table:template>
							<Text textAlign="Right" text="{path: 'SOItems>OrderDate', formatter: 'com.arteriatech.ss.utils.js.Common.getFormattedDate'}"
