						<Text text="{SSGW_SLS>/#SSSO/OrderNo/@sap:label}"/>
						<table:template>
							<Link text="{SOItems>OrderNo}" press="getSODetails" tooltip="{SSGW_SLS>/#SSSO/OrderNo/@sap:label}"/>
							<!--<Text text="{SOItems>OrderNo}" tooltip="{SSGW_SLS>/#SSSO/OrderNo/@sap:label}"/>-->
						</table:template>
					</table:Column>
					<table:Column sortProperty="DmsDivisionDesc" filterProperty="DmsDivisionDesc" tooltip="{SSGW_SLS>/#SSSO/DmsDivision/@sap:label}">
						<Text text="{SSGW_SLS>/#SSSO/DmsDivision/@sap:label}"/>
						<table:template>
							<Text text="{= ${SOItems>DmsDivision} !== '' ? ${SOItems>DmsDivisionDesc} +' ('+ ${SOItems>DmsDivision}+')' : ${SOItems>DmsDivisionDesc} }"
								tooltip="{SSGW_SLS>/#SSSO/DmsDivision/@sap:label}"/>
						</table:template>
