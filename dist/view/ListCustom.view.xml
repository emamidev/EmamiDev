			</HBox>
			<!--MessageStrip-->
			<HBox>
				<MessageStrip text="{i18n>List.Table.MessageStrip.Message}" type="Information" showIcon="true" class="sapUiMediumMarginBottom"
					visible="{LocalViewSetting>/CashDiscPercVisible}"></MessageStrip>
			</HBox>
			<!--sap.ui.table(Visible in Desktop)-->
			<table:Table id="UISOTable" rows="{SOItems>/}" showColumnVisibilityMenu="true" enableGrouping="false" selectionMode="None"
				enableSelectAll="false" noData="{ppcutili18n>common.NoItemSelected}" enableColumnFreeze="true" columnHeaderHeight="55"
				minAutoRowCount="{ path: 'LocalViewSetting>/SOItemsCount', formatter: 'com.arteriatech.ppc.utils.js.Common.setUITableVisibleRowCount'}"
				visibleRowCount="{ path: 'LocalViewSetting>/SOItemsCount', formatter: 'com.arteriatech.ppc.utils.js.Common.setUITableVisibleRowCount'}"
				visible="{= (${device>/system/phone} || ${device>/system/tablet})? false : true}" visibleRowCountMode="Fixed">
				<table:toolbar>
					<Toolbar id="UIListTableToolBar">
						<Title id="UISOTableTitle" text="{i18n>List.Table.SO.header}" level="H1"/>
						<Text id="UIListTableLegend" text="| {i18n>List.Table.legend} : " visible="{LocalViewSetting>/CashDiscPercVisible}"/>
						<Label text="{i18n>List.Table.Toolbar.CashDiscPerc} " tooltip="{i18n>List.Table.Toolbar.CashDiscPerc}" design="Bold"
							visible="{LocalViewSetting>/CashDiscPercVisible}"/>
						<Input id="CashDiscPercinput" textAlign="End" type="Number" value="{LocalViewSetting>/CashDiscPerc}" width="15%" change="onCahDiscChange"
							visible="{LocalViewSetting>/CashDiscPercVisible}" description="%" valueState="{LocalViewSetting>/CashDiscValueState}"
							valueStateText="{LocalViewSetting>/CashDiscValueStateText}"
							maxLength="{path:'SSGW_SLS>/#SSSO2Invoice/CashDiscPerc/@Scale', type:'sap.ui.model.type.Float'}"/>
						<ToolbarSpacer/>
						<Button icon="sap-icon://download" tooltip="{ppcutili18n>common.ExportToExcelTooltip}" press="exportToExcelSalesOrder"/>
					</Toolbar>
				</table:toolbar>
				<table:columns>
					<table:Column width="3rem">
						<CheckBox select="selectAll"/>
						<table:template>
							<CheckBox selected="{SOItems>Selected}" tooltip="Select" select="onSelect"/>
						</table:template>
					</table:Column>
					<table:Column sortProperty="OrderNo" filterProperty="OrderNo" filterType="\{type: 'sap.ui.model.type.Float'\}"
