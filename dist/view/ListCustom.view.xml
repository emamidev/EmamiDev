<mvc:View class="sapUiResponsiveMargin" controllerName="com.arteriatech.ss.soinvcreate.cp.controller.List" displayBlock="true" width="auto"
	xmlns:core="sap.ui.core" xmlns:fb="sap.ui.comp.filterbar" xmlns:html="http://www.w3.org/1999/xhtml" xmlns:l="sap.ui.layout"
	xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:table="sap.ui.table">
	<fb:FilterBar id="SOItemsFilterBar" reset="onReset" search="onSearch" showRestoreButton="false" showRestoreOnFB="false"
		filterContainerWidth="15rem" simplifiedMode="true">
		<fb:filterItems>
			<fb:FilterItem id="Customer" label="{SFGW_MST>/Customers/CustomerNo/#@sap:label}"
				labelTooltip="{SFGW_MST>/Customers/CustomerNo/#@sap:label}" name="Customer" visible="{LocalViewSetting>/CustomerDD}">
				<fb:control>
					<Select autoAdjustWidth="true" change="getSelectedCustomerName" id="customer" items="{Customers>/}" showSecondaryValues="true">
						<core:ListItem additionalText="{Customers>CustomerNo}" id="customer_item" key="{Customers>CustomerNo}"
							text="{Customers>CustomerNo}{Customers>Seperator}{Customers>Name}" tooltip="{Customers>Name}"></core:ListItem>
					</Select>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="CustomerNo" label="{SFGW_MST>/Customers/CustomerNo/#@sap:label}"
				labelTooltip="{SFGW_MST>/Customers/CustomerNo/#@sap:label}" name="CustomerNo" visible="{LocalViewSetting>/CustomerVH}">
				<fb:control>
					<MultiInput id="inputCustomerNo" maxLength="{path:'SSGW_SLS>/#SSSO/CustomerNo/@maxLength', type:'sap.ui.model.type.Float'}"
						valueHelpRequest="CustomerF4"/>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="OrderType" label="{SSGW_SLS>/#SSSO/OrderType/@sap:label}" labelTooltip="{SSGW_SLS>/#SSSO/OrderType/@sap:label}"
				name="OrderType">
				<fb:control>
					<MultiComboBox autoAdjustWidth="true" id="inputOrderType" items="{OrderTypeDD>/}" showSecondaryValues="true">
						<core:Item additionalText="{OrderTypeDD>Text}" id="inputOrderType_item" key="{OrderTypeDD>Key}"
							text="{OrderTypeDD>Key}{OrderTypeDD>Seperator}{OrderTypeDD>Text}" tooltip="{OrderTypeDD>Text}"></core:Item>
					</MultiComboBox>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="OrderNo" label="{SSGW_SLS>/#SSSO/OrderNo/@sap:label}" labelTooltip="{SSGW_SLS>/#SSSO/OrderNo/@sap:label}" name="OrderNo">
				<fb:control>
					<MultiInput id="inputOrderNo" tokenChange="tokenChangeOrderNo"
						maxLength="{path:'SSGW_SLS>/#SSSO/OrderNo/@maxLength', type:'sap.ui.model.type.Float'}" valueHelpRequest="OrderNoF4" change="onSONo"
						showTableSuggestionValueHelp="true" showSuggestion="true" filterSuggests="false" suggest="handleSONOSuggest"
						suggestionItemSelected="suggestionSONoSelected" suggestionItems="{SONoSuggestorModel>/}">
						<suggestionItems>
							<core:ListItem text="{SONoSuggestorModel>SONo}" additionalText="{SONoSuggestorModel>OrderType}"/>
						</suggestionItems>
					</MultiInput>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="fiOrderDate" label="{SSGW_SLS>/#SSSO/OrderDate/@sap:label}" labelTooltip="{SSGW_SLS>/#SSSO/OrderDate/@sap:label}"
				mandatory="true" name="fiOrderDate">
				<fb:control>
					<Select autoAdjustWidth="true" change="onSODateSelectionChanged" id="inputSODate" items="{SODateViewSetting>/}" name="OrderDate">
						<core:ListItem id="OrderDate_item" key="{SODateViewSetting>DateKey}" text="{SODateViewSetting>DateDesc}"
							tooltip="{SODateViewSetting>DateDesc}"></core:ListItem>
					</Select>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="fiSPNo" label="{SSGW_SLS>/#SSSO/SPNo/@sap:label}" labelTooltip="{SSGW_MST>/#SSSO/SPNo/@sap:label}" name="SPNo">
				<fb:control>
					<MultiInput id="multiInputSPNo" maxLength="{path:'SSGW_SLS>/#SSSO/SPGUID/@maxLength', type:'sap.ui.model.type.Float'}"
						valueHelpRequest="SPNoF4" change="onChangeSPF4" showTableSuggestionValueHelp="true" showSuggestion="true" filterSuggests="false"
						suggest="handleSalesPersonSuggest" suggestionItemSelected="suggestionItemSelectedSP" suggestionItems="{SalesPersonSuggestorModel>/}">
						<suggestionItems>
							<core:ListItem text="{SalesPersonSuggestorModel>FirstName}" additionalText="{SalesPersonSuggestorModel>SPNo}"/>
						</suggestionItems>
					</MultiInput>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="LDescription" name="Description" label="{SSGW_SLS>/#SSSO/BeatCode/@sap:label}"
				labelTooltip="{SSGW_SLS>/#SSSO/BeatCode/@sap:label}" mandatory="false">
				<fb:control>
					<MultiInput id="FDescription" change="onChangeRouteName" valueHelpRequest="RouteNameF4" suggestionItems="{RouteNameSuggestorModel>/}"
						suggestionItemSelected="suggestionItemSelectedRoute" suggest="handleRouteNameSuggest" filterSuggests="false" showSuggestion="true"
						showTableSuggestionValueHelp="true">
						<suggestionItems>
							<core:ListItem id="listItemRouteName" text="{RouteNameSuggestorModel>Description}" additionalText="{RouteNameSuggestorModel>RoutId}"/>
						</suggestionItems>
					</MultiInput>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="fiRetailer" label="{SSGW_SLS>/#SSSO/SoldToId/@sap:label}" labelTooltip="{SSGW_MST>/#SSSO/SoldToId/@sap:label}"
				name="Retailer">
				<fb:control>
					<MultiInput id="multiInputCPNo" maxLength="{path:'SSGW_SLS>/#SSSO/SoldToId/@maxLength', type:'sap.ui.model.type.Float'}"
						valueHelpRequest="CPNoF4" change="onChangeCPF4" showTableSuggestionValueHelp="true" showSuggestion="true" filterSuggests="false"
						suggest="handleChannelPartnerSuggest" suggestionItemSelected="suggestionItemSelected" suggestionItems="{ChannelPartnerSuggestorModel>/}">
						<suggestionItems>
							<core:ListItem text="{ChannelPartnerSuggestorModel>Name}" additionalText="{ChannelPartnerSuggestorModel>CPNo}"/>
						</suggestionItems>
					</MultiInput>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="Material" label="{SSGW_SLS>/#SSSOItem/MaterialNo/@sap:label}" labelTooltip="{SSGW_SLS>/#SSSO/MaterialNo/@sap:label}"
				name="Material" visible="false">
				<fb:control>
					<MultiInput id="inputMaterial" maxLength="{path:'SSGW_SLS>/#SSSO/MaterialNo/@maxLength', type:'sap.ui.model.type.Float'}"
						valueHelpRequest="MaterialF4" showTableSuggestionValueHelp="true" showSuggestion="true" filterSuggests="false"
						suggest="handleMaterialSuggest" suggestionItemSelected="suggestionItemSelectedMat" suggestionItems="{MaterialSuggestorModel>/}"
						change="onChangeMaterial">
						<suggestionItems>
							<core:ListItem text="{MaterialSuggestorModel>MaterialDesc}" additionalText="{MaterialSuggestorModel>MaterialNo}"/>
						</suggestionItems>
					</MultiInput>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="OrderMaterial" label="{SSGW_SLS>/#SSSO/OrderMatGrp/@sap:label}" labelTooltip="{SSGW_SLS>/#SSSO/OrderMatGrp/@sap:label}"
				name="OrderMaterial" visible="false">
				<fb:control>
					<MultiInput id="inputOrderMaterial" maxLength="{path:'SSGW_SLS>/#SSSO/MaterialNo/@maxLength', type:'sap.ui.model.type.Float'}"
						valueHelpRequest="OrderMaterialF4"></MultiInput>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="Status" label="{SSGW_SLS>/#SSSO/Status/@sap:label}" labelTooltip="Status" name="Status" visible="true">
				<fb:control>
					<MultiComboBox autoAdjustWidth="true" id="inputStatus" items="{StatusDD>/}" showSecondaryValues="true">
						<core:Item additionalText="{StatusDD>Text}" id="inputStatus_item" key="{StatusDD>Key}"
							text="{StatusDD>Key}{StatusDD>Seperator}{StatusDD>Text}" tooltip="{StatusDD>Text}"></core:Item>
					</MultiComboBox>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="BilForm" label="Bill From" labelTooltip="Bill From" name="Bill" visible="true">
				<fb:control>
					<Select autoAdjustWidth="true" id="inputBillForm" change="onChangeBillForm" items="{BillFormDD>/}" showSecondaryValues="true">
						<core:Item id="Bill_item" key="{BillFormDD>Key}" text="{BillFormDD>Key}{BillFormDD>Seperator}{BillFormDD>Text}" tooltip="{BillFormDD>Text}"></core:Item>
					</Select>
				</fb:control>
			</fb:FilterItem>
			<fb:FilterItem id="ApprovalStatus" label="{SSGW_SLS>/#SSSO/ApprovalStatus/@sap:label}"
				labelTooltip="{SSGW_SLS>/#SSSO/ApprovalStatus/@sap:label}" name="ApprovalStatus" visible="false">
				<fb:control>
					<MultiComboBox autoAdjustWidth="true" id="inputApprovalStatus" items="{ApprovalStatusDD>/}" showSecondaryValues="true">
						<core:Item additionalText="{ApprovalStatusDD>Text}" id="inputApprovalStatus_item" key="{ApprovalStatusDD>Key}"
							text="{ApprovalStatusDD>Key}{ApprovalStatusDD>Seperator}{ApprovalStatusDD>Text}" tooltip="{ApprovalStatusDD>Text}"></core:Item>
					</MultiComboBox>
				</fb:control>
			</fb:FilterItem>
		</fb:filterItems>
	</fb:FilterBar>
