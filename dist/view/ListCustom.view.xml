					<ObjectStatus id="UIListTableLegendIcon_2" icon="sap-icon://status-inactive" text="Partially Processed" tooltip="Partially Processed"
						state="Warning" visible="{= ${device>/system/phone}? false : true}" class="sapUiTinyMarginEnd"/>
					<ObjectStatus id="UIListTableLegendIcon_3" icon="sap-icon://alert" text="Bill Generated" tooltip="Closed" state="Success"
						visible="{= ${device>/system/phone}? false : true}" class="sapUiTinyMarginEnd"/>
					<ObjectStatus id="UIListTableLegendIcon_4" icon="sap-icon://status-negative" text="Rejected" tooltip="Rejected" state="Error"
