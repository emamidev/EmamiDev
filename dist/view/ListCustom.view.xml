						tooltip="{SSGW_SLS>/#SSSO/GrossAmt/@sap:label}">
						<Text textAlign="Right" text="{SSGW_SLS>/#SSSO/GrossAmt/@sap:label}"/>
						<table:template>
							<ObjectNumber textAlign="Right" emphasized="false"
