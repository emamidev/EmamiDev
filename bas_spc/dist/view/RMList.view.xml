<mvc:View
    controllerName="com.emami.spc.controller.RMList"
    xmlns:core="sap.ui.core"
    xmlns="sap.uxap"
    xmlns:l="sap.ui.layout"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    height="100%"
>
    <ObjectPageLayout
        showTitleInHeaderContent="true"
        upperCaseAnchorBar="false"
        showFooter="true"
    >
        <headerTitle>
            <core:Fragment fragmentName="com.emami.spc.view.fragments.HomeHeaderTitle" type="XML" />
        </headerTitle>

        <headerContent>
            <core:Fragment fragmentName="com.emami.spc.view.fragments.SpecificationListInput" type="XML" />
        </headerContent>

        <sections>
            <core:Fragment fragmentName="com.emami.spc.view.fragments.RMPendingList" type="XML" />
            <core:Fragment fragmentName="com.emami.spc.view.fragments.RMSpecificList" type="XML" />
        </sections>
       
    </ObjectPageLayout>
</mvc:View>
