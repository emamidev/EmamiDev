<core:FragmentDefinition
    xmlns:m="sap.m" 
    xmlns:core="sap.ui.core"
    xmlns="sap.uxap"
    xmlns:l="sap.ui.layout"
    xmlns:fb="sap.ui.comp.filterbar"
>
    <m:HeaderContainer showDividers="false">
        <!-- <l:VerticalLayout width="100%"> -->
        <!-- <l:HorizontalLayout> -->

        <!-- <m:FlexBox
            direction="Column"
            justifyContent="Start"
            alignItems="Start"
            width="100%"
        > -->
        <m:FlexBox
            direction="{= ${device>/system/phone} ? 'Column' : 'Row' }"
            alignItems="Center"
            justifyContent="Start"
            wrap="Wrap"
        >
            <m:DatePicker
                placeholder="From Date"
                width="8rem"
                class="sapUiTinyMarginEnd"
                value="{ path : 'jsonCentralModel>/Home/FromDate' , type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}"
            />

            <m:DatePicker
                placeholder="To Date"
                width="8rem"
                class="sapUiTinyMarginEnd"
                value="{ path : 'jsonCentralModel>/Home/ToDate' , type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}"
            />

            <m:Input
                width="8rem" 
                class="sapUiTinyMarginEnd"
                placeholder="Material Code" 
                value="{jsonCentralModel>/Home/SelectedMaterialCode}" 
                valueHelpRequest="onMaterialListValueHelpReq"
                change="onChangeMaterialListInput"
                showValueHelp="true"
            />
            <m:Button
                class="sapUiTinyMarginEnd"
                text="Create"
                press="onPressCreate"
                type="Emphasized"
                visible="{jsonCentralModel>/Home/VisibleCreateBtn}"
                enabled="{jsonCentralModel>/Home/EnableDisableCreate}"
            />
            <m:Button
                class="sapUiTinyMarginEnd"
                icon="sap-icon://search"
                press="onPressSearch"
                type="Emphasized"
            />
            <m:Button
                icon="sap-icon://clear-filter"
                press="onPressClear"
                type="Emphasized"
            />
        </m:FlexBox>
        <!-- </m:FlexBox> -->
        <!-- </l:HorizontalLayout> -->
        <!-- </l:VerticalLayout> -->
    </m:HeaderContainer>
</core:FragmentDefinition>
