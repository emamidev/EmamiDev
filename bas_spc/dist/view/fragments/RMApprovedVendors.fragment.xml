<core:FragmentDefinition
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns="sap.uxap"
>
    <ObjectPageSection
        titleUppercase="false"
        title=""
    >
        <subSections>
            <ObjectPageSubSection titleUppercase="false">
                <blocks>
                    <m:Table
                        popinLayout="GridSmall"
                        sticky="ColumnHeaders"
                    >
                        <m:columns>
                            <m:Column>
                                <m:Text text="Description" />
                            </m:Column>
                            <m:Column>
                                <m:Text text="Prepared By" />
                            </m:Column>
                            <m:Column>
                                <m:Text text="Checked By" />
                            </m:Column>
                            <m:Column>
                                <m:Text text="Approved By" />
                            </m:Column>
                        </m:columns>

                        <m:items>
                            <!-- <m:ColumnListItem>
                                <m:cells>
                                    <m:Text text="Signature" />
                                    <m:Text text="" />
                                    <m:Text text="" />
                                    <m:Text text="" />
                                </m:cells>
                            </m:ColumnListItem> -->
                            <m:ColumnListItem>
                                <m:cells>
                                    <m:Text text="Name" />
                                    <m:Text
                                        text="{jsonCentralModel>/RawMaterial/Data/Createdby}"
                                    />
                                    <m:Text
                                        text="{jsonCentralModel>/RawMaterial/Data/Reviewby}"
                                    />
                                    <m:Text
                                        text="{jsonCentralModel>/RawMaterial/Data/Aproveby}"
                                    />
                                </m:cells>
                            </m:ColumnListItem>
                            <m:ColumnListItem>
                                <m:cells>
                                    <m:Text text="Date" />
                                    <m:Text
                                        text="{ path : 'jsonCentralModel>/RawMaterial/Data/Createdon' , type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}"
                                    />
                                    <m:Text
                                        text="{ path : 'jsonCentralModel>/RawMaterial/Data/Reviewon' , type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}"
                                    />
                                    <m:Text
                                        text="{ path : 'jsonCentralModel>/RawMaterial/Data/Aproveon' , type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}"
                                    />
                                </m:cells>
                            </m:ColumnListItem>
                        </m:items>
                    </m:Table>
                </blocks>
            </ObjectPageSubSection>
        </subSections>
    </ObjectPageSection>
</core:FragmentDefinition>
