                     <ui:Table
                        rows="{jsonCentralModel>/RawMaterial/Data/ApprovedVendors/results}"
                        selectionMode="None"
                        paste="onPaste"
                        ariaLabelledBy="title"
                        visibleRowCount="5"
                    >
                    <ui:extension>
                            <m:OverflowToolbar style="Clear">
                                <m:ToolbarSpacer />
                                <m:Button
                                    press="onAddApprovedItem"
                                    icon="sap-icon://add"
                                    type="Accept"
                                    visible="{jsonCentralModel>/RawMaterial/Editable/All}"
                                />
                            </m:OverflowToolbar>
                        </ui:extension>
                        <ui:columns>
                            <ui:Column width="3rem">
                                <m:Label text="Sl." />
                                <ui:template>
                                    <m:Text
                                        text="{jsonCentralModel>Posnr}"
                                        wrapping="false"
                                    />
                                    <!-- <m:Input
                                        value="{jsonCentralModel>Posnr}" editable="{jsonCentralModel>/RawMaterial/Editable/All}"
                                    /> -->
                                </ui:template>
                            </ui:Column>
                            <ui:Column width="25rem">
                                <m:Label text="Approved Manufacturer" />
                                <ui:template>
                                    <!-- <m:Text
                                        text="{jsonCentralModel>Approvedmfd}"
                                        wrapping="false"
                                    /> -->
                                    <m:Input
                                        value="{jsonCentralModel>Approvedmfd}" editable="{jsonCentralModel>/RawMaterial/Editable/All}" tooltip="{jsonCentralModel>Approvedmfd}"
                                    />
                                </ui:template>
                            </ui:Column>
                            <ui:Column width="25rem">
                                <m:Label text="Site Plant" />
                                <ui:template>
                                    <!-- <m:Text
                                        text="{jsonCentralModel>Siteplant}"
                                        wrapping="false"
                                    /> -->
                                    <m:Input
                                        value="{jsonCentralModel>Siteplant}" editable="{jsonCentralModel>/RawMaterial/Editable/All}" tooltip="{jsonCentralModel>Siteplant}"
                                    />
                                </ui:template>
                            </ui:Column>
                             <ui:Column width="10rem">
                                <m:Label text="Trade Name" />
                                <ui:template>
                                    <m:Input
                                        value="{jsonCentralModel>Tradename}" editable="{jsonCentralModel>/RawMaterial/Editable/All}" tooltip="{jsonCentralModel>Tradename}"
                                    />
                                </ui:template>
                            </ui:Column>
                             <ui:Column width="10rem">
                                <m:Label text="Pack Size" />
                                <ui:template>
                                    <m:Input
                                        value="{jsonCentralModel>Packsize}" editable="{jsonCentralModel>/RawMaterial/Editable/All}" tooltip="{jsonCentralModel>Packsize}"
                                    />
                                </ui:template>
                            </ui:Column>
                            <ui:Column width="5rem" visible="{jsonCentralModel>/RawMaterial/Editable/All}">
                                <m:Label text="Remove" />
                                <ui:template>
                                    <m:Button
                                        press="onDeleteApproved"
                                        icon="sap-icon://delete"
                                        type="Reject"
                                        
                                    />
                                </ui:template>
                            </ui:Column>
                        </ui:columns>
                    </ui:Table>
                </blocks>
            </ObjectPageSubSection>
        </subSections>
    </ObjectPageSection>
</core:FragmentDefinition>
