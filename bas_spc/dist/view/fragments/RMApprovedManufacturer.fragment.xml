                            <m:Column>
                                <m:Text text="Sl.No" />
                            </m:Column>
                            <m:Column>
                                <m:Text text="Approved Manufacturer" />
                            </m:Column>
                            <m:Column>
                                <m:Text text="Site Plant" />
                            </m:Column>
                            <m:Column>
                                <m:Text text="Trade Name" />
                            </m:Column>
                            <m:Column>
                                <m:Text text="Pack Size" />
                            </m:Column>
                        </m:columns>

                        <m:items>
                            <m:ColumnListItem>
                                <m:cells>
                                    <m:Text text="{jsonCentralModel>Posnr}" />
                                    <m:Text text="{jsonCentralModel>Approvedmfd}" />
                                    <m:Text text="{jsonCentralModel>Siteplant}" />
                                    <m:Input value="{jsonCentralModel>Tradename}"  editable="{jsonCentralModel>/RawMaterial/Editable/All}" />
