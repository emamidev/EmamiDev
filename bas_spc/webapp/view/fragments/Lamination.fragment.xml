<core:FragmentDefinition
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns="sap.uxap"
>
  <ObjectPageSection
                titleUppercase="false"
                title="Lamination"
            >
                <subSections>
                    <ObjectPageSubSection titleUppercase="false">
                        <blocks>
                            <m:HBox>
                                <m:Select
                                    selectedKey="{jsonCentralModel>/Data/Lamination/Lamin}"
                                    width="5rem"
                                    enabled="{jsonCentralModel>/PackagingMaterialEditable/All}"
                                >
                                    <m:items>
                                        <core:Item
                                            key="Yes"
                                            text="Yes"
                                        />
                                        <core:Item
                                            key="NA"
                                            text="NA"
                                        />
                                         <core:Item
                                            key=""
                                            text=""
                                        />
                                    </m:items>
                                </m:Select>

                                <m:Select
                                    selectedKey="{jsonCentralModel>/Data/Lamination/Gsm}"
                                    width="5rem"
                                    class="sapUiMediumMarginBegin"
                                    enabled="{jsonCentralModel>/PackagingMaterialEditable/All}"
                                >
                                    <m:items>
                                        <core:Item
                                            key="8µ"
                                            text="8µ"
                                        />
                                        <core:Item
                                            key="10µ"
                                            text="10µ"
                                        />
                                        <core:Item
                                            key="12µ"
                                            text="12µ"
                                        />
                                        <core:Item
                                            key="15µ"
                                            text="15µ"
                                        />
                                        <core:Item
                                            key="18µ"
                                            text="18µ"
                                        />
                                        <core:Item
                                            key=""
                                            text=""
                                        />
                                    </m:items>
                                </m:Select>

                                <m:Select
                                    selectedKey="{jsonCentralModel>/Data/Lamination/Mtlsd}"
                                    width="8rem"
                                    class="sapUiMediumMarginBegin"
                                    enabled="{jsonCentralModel>/PackagingMaterialEditable/All}"
                                >
                                    <m:items>
                                        <core:Item
                                            key="Metalised"
                                            text="Metalised"
                                        />
                                        <core:Item
                                            key="Natural"
                                            text="Natural"
                                        />
                                        <core:Item
                                            key="Matt"
                                            text="Matt"
                                        />
                                        <core:Item
                                            key=""
                                            text=""
                                        />
                                    </m:items>
                                </m:Select>

                                <m:Select
                                    selectedKey="{jsonCentralModel>/Data/Lamination/Petpvc}"
                                    width="6rem"
                                    class="sapUiMediumMarginBegin"
                                    enabled="{jsonCentralModel>/PackagingMaterialEditable/All}"
                                >
                                    <m:items>
                                        <core:Item
                                            key="PET"
                                            text="PET"
                                        />
                                        <core:Item
                                            key="PVC"
                                            text="PVC"
                                        />
                                        <core:Item
                                            key="BOPP"
                                            text="BOPP"
                                        />
                                        <core:Item
                                            key=""
                                            text=""
                                        />
                                    </m:items>
                                </m:Select>
                            </m:HBox>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
</core:FragmentDefinition>