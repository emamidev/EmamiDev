<core:FragmentDefinition
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns="sap.uxap"
>
    <ObjectPageSection
        titleUppercase="false"
        title="Specific List"
    >
        <subSections>
            <ObjectPageSubSection titleUppercase="false">
                <blocks>
                    <m:ScrollContainer
                        height="200px"
                        width="100%"
                        horizontal="false"
                        vertical="true"
                    >
                        <m:Table
                            items="{jsonRMSpecificListModel>/}"
                            popinLayout="GridSmall"
                            sticky="ColumnHeaders"
                        >
                            <m:columns>
                                <m:Column>
                                    <m:Text text="Material" />
                                </m:Column>
                                <m:Column>
                                    <m:Text text="Description" />
                                </m:Column>

                                <m:Column>
                                    <m:Text text="Version" />
                                </m:Column>

                                <m:Column>
                                    <m:Text text="Issued on" />
                                </m:Column>

                                <m:Column>
                                    <m:Text text="Status" />
                                </m:Column>

                                <m:Column>
                                    <m:Text text="Pending With" />
                                </m:Column>
                            </m:columns>

                            <m:items>
                                <m:ColumnListItem
                                    type="Navigation"
                                    press="onPressLineItem"
                                >
                                    <m:cells>
                                        <m:Text
                                            text="{jsonRMSpecificListModel>Matnr}"
                                        />
                                        <m:Text
                                            text="{jsonRMSpecificListModel>Maktx}"
                                        />
                                        <m:Text
                                            text="{jsonRMSpecificListModel>Versn}"
                                        />
                                        <m:Text
                                            text="{ path : 'jsonRMSpecificListModel>IssueDate' , type: 'sap.ui.model.type.Date', formatOptions: {pattern: 'dd/MM/yyyy'}}"
                                        />
                                        <m:Text
                                            text="{jsonRMSpecificListModel>Status}"
                                        />
                                        <m:Text
                                            text="{jsonRMSpecificListModel>Pendwith}"
                                        />
                                    </m:cells>
                                </m:ColumnListItem>
                            </m:items>
                        </m:Table>
                    </m:ScrollContainer>
                </blocks>
            </ObjectPageSubSection>
        </subSections>
    </ObjectPageSection>
</core:FragmentDefinition>
