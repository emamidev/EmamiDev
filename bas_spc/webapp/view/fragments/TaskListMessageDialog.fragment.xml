<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
>
    <Dialog
        title="Message"
        contentHeight="60%"
        contentWidth="60%"
    >
        <Table
            items="{jsonTaskListMessageModel>/}"
            popinLayout="GridSmall"
            sticky="ColumnHeaders"
        >
            <columns>
                <Column>
                    <Text text="Type" />
                </Column>
                <Column>
                    <Text text="Id" />
                </Column>
                <Column>
                    <Text text="Number" />
                </Column>
                <Column>
                    <Text text="Message" />
                </Column>
            </columns>

            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{jsonTaskListMessageModel>Type}" />
                        <Text text="{jsonTaskListMessageModel>Id}" />
                        <Text text="{jsonTaskListMessageModel>Number}" />
                        <Text text="{jsonTaskListMessageModel>Message}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
        <buttons>
            <Button
                text="Close"
                type="Emphasized"
                press="onPressHome"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
