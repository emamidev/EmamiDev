<core:FragmentDefinition
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns="sap.uxap"
    xmlns:l="sap.ui.layout"
>
    <ObjectPageDynamicHeaderTitle>
        <content>
            <m:HBox>
                <m:VBox> 
                    <m:Image
                         src="{ path: 'jsonCentralModel>/logo/emami',
                                                formatter: '.formatter.logo'
                                            }"
                        height="6rem"
                        width="7rem"
                        press="onPressHome" 
                    />
                </m:VBox>
                <m:VBox>
                    <m:FlexBox
                        justifyContent="Center"
                        alignItems="Center"
                        height="100%"
                        class="sapUiResponsiveMargin"
                    >
                        <m:items>
                            <m:Title
                                text="{jsonCentralModel>/AppTitle}"
                                wrapping="true"
                                titleStyle="H4"
                            />
                        </m:items>
                    </m:FlexBox>

                    <!-- <m:FlexBox
                        height="100px"
                        alignItems="Center"
                        justifyContent="Center"
                    >
                        <m:Title
                            text="{jsonCentralModel>/AppTitle}"
                            wrapping="true"
                            titleStyle="H4"
                        />
                    </m:FlexBox> -->
                </m:VBox>
            </m:HBox>
        </content>
    </ObjectPageDynamicHeaderTitle>
</core:FragmentDefinition>
