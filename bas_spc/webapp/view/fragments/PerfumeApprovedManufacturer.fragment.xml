<core:FragmentDefinition
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns="sap.uxap"
     xmlns:ui="sap.ui.table"
>
    <ObjectPageSection
        titleUppercase="false"
        title="Approved Vendors" 
    >
        <subSections>
            <ObjectPageSubSection titleUppercase="false">
                <blocks>
                  
                     <ui:Table
                        rows="{jsonCentralModel>/PerfumeMaterial/Data/PRMApprovedVendor/results}"
                        selectionMode="None"
                        paste="onPaste"
                        ariaLabelledBy="title"
                        visibleRowCount="5"
                    >
                    <ui:extension>
                            <m:OverflowToolbar style="Clear">
                                <m:ToolbarSpacer />
                                <m:Button
                                    press="onAddApprovedItemPRM"
                                    icon="sap-icon://add"
                                    type="Accept"
                                    visible="{jsonCentralModel>/PerfumeMaterial/Editable/All}"
                                />
                            </m:OverflowToolbar>
                        </ui:extension>
                        <ui:columns>
                            <ui:Column width="3rem">
                                <m:Label text="Sl." />
                                <ui:template>
                                    <m:Text
                                        text="{jsonCentralModel>Posnr}"
                                        wrapping="false"
                                    />
                                </ui:template>
                            </ui:Column>
                            <ui:Column width="25rem">
                                <m:Label text="Approved Manufacturer" />
                                <ui:template>
                                    <m:Input
                                        value="{jsonCentralModel>Approvedmfd}" editable="{jsonCentralModel>/PerfumeMaterial/Editable/All}" tooltip="{jsonCentralModel>Approvedmfd}"
                                    />
                                </ui:template>
                            </ui:Column>
                            <ui:Column width="25rem">
                                <m:Label text="Site Plant" />
                                <ui:template>
                                    <m:Input
                                        value="{jsonCentralModel>Siteplant}" editable="{jsonCentralModel>/PerfumeMaterial/Editable/All}" tooltip="{jsonCentralModel>Siteplant}"
                                    />
                                </ui:template>
                            </ui:Column>
                             <ui:Column width="10rem">
                                <m:Label text="Trade Name" />
                                <ui:template>
                                    <m:Input
                                        value="{jsonCentralModel>Tradename}" editable="{jsonCentralModel>/PerfumeMaterial/Editable/All}" tooltip="{jsonCentralModel>Tradename}"
                                    />
                                </ui:template>
                            </ui:Column>
                             <ui:Column width="10rem">
                                <m:Label text="Pack Size" />
                                <ui:template>
                                    <m:Input
                                        value="{jsonCentralModel>Packsize}" editable="{jsonCentralModel>/PerfumeMaterial/Editable/All}" tooltip="{jsonCentralModel>Packsize}"
                                    />
                                </ui:template>
                            </ui:Column>
                            <ui:Column width="5rem" visible="{jsonCentralModel>/PerfumeMaterial/Editable/All}">
                                <m:Label text="Remove" />
                                <ui:template>
                                    <m:Button
                                        press="onDeleteApprovedPRM"
                                        icon="sap-icon://delete"
                                        type="Reject"
                                        
                                    />
                                </ui:template>
                            </ui:Column>
                        </ui:columns>
                    </ui:Table>
                </blocks>
            </ObjectPageSubSection>
        </subSections>
    </ObjectPageSection>
</core:FragmentDefinition>
